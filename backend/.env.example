# ---- EDM backend environment (mirrors the Laravel .env) ----
# Defaults point to LOCAL MongoDB so this never touches the production droplet.

APP_NAME="Election Data Management"
APP_ENV=local
PORT=5000

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=1d

# Admin bootstrap credentials (used when no user exists in the app DB)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# DB1: Voter roll (ass_1..ass_234). Local dev default.
# Production is 127.0.0.1:27017 on the droplet (not reachable remotely).
MONGO_VOTER_URL=mongodb://127.0.0.1:27017
MONGO_VOTER_DB_NAME=voter_db

# DB2: App data (users, tbl_assembly_consitituency, payments...). Local dev default.
# Production is MongoDB Atlas.
MONGO_APP_URL=mongodb://127.0.0.1:27017
MONGO_APP_DB_NAME=election_app

# Frontend origin for CORS
CLIENT_ORIGIN=http://localhost:5173

# Integrations (placeholders - fill when implementing those modules)
RAZORPAY_KEY=
RAZORPAY_SECRET=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
